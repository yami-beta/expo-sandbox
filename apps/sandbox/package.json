    "eslint-config-expo": "~56.0.4",
    "eslint-plugin-oxlint": "^1.66.0",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "oxlint-tsgolint": "^0.23.0",
    "typescript": "~6.0.3"
  }
